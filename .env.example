# Path or name of the Codex CLI binary
CODEX_CMD=codex

# Path or name of the Claude CLI binary
CLAUDE_CMD=claude

# Path or name of the Gemini CLI binary
GEMINI_CMD=gemini

# Seconds before a delegated call times out
DELEGATE_TIMEOUT_SECONDS=300

# Maximum characters allowed in a task string
DELEGATE_MAX_TASK_CHARS=12000

# Strip ANSI escape codes from CLI output
STRIP_ANSI=true

# Use --json flag with codex exec (JSONL output)
CODEX_JSON_MODE=true

# Context blocks longer than this are written to a temp file instead of inlined
TASK_CONTEXT_THRESHOLD_CHARS=2000

# Subdirectory name (inside cwd) for temp context files
TMP_DIR_NAME=.mcp_tmp

# How often (seconds) to send a progress notification during long-running delegate calls
PROGRESS_INTERVAL_SECONDS=15

# Subdirectory name (inside cwd) for interaction history files
HISTORY_DIR_NAME=.mcp_history

# How many previous interactions to show in the history footer of each response
HISTORY_FOOTER_ENTRIES=2

# Max characters per entry in the history footer summary
HISTORY_SUMMARY_CHARS=80

# Maximum delegate chain depth (1 = subprocesses cannot re-delegate, preventing loops)
MAX_DELEGATE_DEPTH=1

# Comma-separated list of delegates to disable for this instance.
# Set to the name of the orchestrator running the server to prevent self-calls.
# Example: if Gemini is the orchestrator, set DISABLED_DELEGATES=gemini
DISABLED_DELEGATES=
